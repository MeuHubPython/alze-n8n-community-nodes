{
	"name": "n8n-nodes-alze",
	"version": "1.0.8",
	"description": "n8n community nodes for Alze CRM",
	"license": "MIT",
	"homepage": "https://github.com/MeuHubPython/alze-n8n-community-nodes",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "MeuHubPython",
		"email": "contato@meuhubpython.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/MeuHubPython/alze-n8n-community-nodes.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": true,
		"credentials": [
			"dist/credentials/AlzeApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Alze/Alze.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "^9.0.0",
		"prettier": "3.8.3",
		"release-it": "20.0.1",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
